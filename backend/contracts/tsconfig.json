{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "hardhat"]
  },
  "include": ["./hardhat.config.ts", "./scripts/**/*.ts", "./test/**/*.ts"]
}
